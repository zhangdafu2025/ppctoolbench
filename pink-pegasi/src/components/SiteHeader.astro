---
const { currentPath = "/" } = Astro.props;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/utm-builder", label: "UTM Builder" },
  { href: "/google-ads-character-counter", label: "Ad Counter" },
  { href: "/google-ads-headline-generator", label: "Headline Tool" },
  { href: "/google-ads-preview-tool", label: "Ad Preview" },
  { href: "/google-ads-description-generator", label: "Desc Tool" }
];
---

<header class="site-header">
  <div class="site-header-inner">
    <div class="brand-wrap">
      <a href="/" class="brand" aria-label="PPC Tool Bench Home">
        <span class="brand-mark">PT</span>
        <span class="brand-text">
          <span class="brand-title">PPC Tool Bench</span>
          <span class="brand-subtitle">Free PPC & SEO Tools</span>
        </span>
      </a>
    </div>

    <nav class="nav" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={currentPath === link.href ? "active" : ""}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="/utm-builder" class="cta-btn">Try UTM Builder</a>
    </div>
  </div>
</header>

<style>
.site-header{
  position:sticky;
  top:0;
  z-index:50;
  background:rgba(255,255,255,0.94);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  border-bottom:1px solid #e5e7eb;
  margin-bottom:32px;
}

.site-header-inner{
  max-width:1100px;
  margin:0 auto;
  padding:14px 20px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
}

.brand-wrap{
  flex-shrink:0;
}

.brand{
  display:inline-flex;
  align-items:center;
  gap:12px;
  text-decoration:none;
}

.brand-mark{
  width:42px;
  height:42px;
  border-radius:12px;
  background:#111827;
  color:#ffffff;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  font-size:14px;
  font-weight:800;
  letter-spacing:0.02em;
}

.brand-text{
  display:flex;
  flex-direction:column;
  line-height:1.1;
}

.brand-title{
  font-size:16px;
  font-weight:800;
  color:#111827;
}

.brand-subtitle{
  margin-top:3px;
  font-size:12px;
  color:#6b7280;
}

.nav{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:16px;
  flex:1;
  flex-wrap:wrap;
}

.nav a{
  color:#374151;
  font-size:14px;
  font-weight:600;
  text-decoration:none;
  padding-bottom:3px;
  border-bottom:2px solid transparent;
  transition:color 0.2s ease, border-color 0.2s ease;
}

.nav a:hover{
  color:#2563eb;
}

.nav a.active{
  color:#2563eb;
  border-bottom-color:#2563eb;
}

.header-cta{
  flex-shrink:0;
}

.cta-btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 16px;
  border-radius:12px;
  background:#111827;
  color:#ffffff;
  text-decoration:none;
  font-size:14px;
  font-weight:700;
  transition:background 0.2s ease;
}

.cta-btn:hover{
  background:#1f2937;
}

@media (max-width: 980px){
  .site-header-inner{
    flex-direction:column;
    align-items:flex-start;
  }

  .nav{
    justify-content:flex-start;
  }
}

@media (max-width: 640px){
  .site-header{
    margin-bottom:24px;
  }

  .site-header-inner{
    padding:14px 16px;
  }

  .brand-title{
    font-size:15px;
  }

  .nav{
    gap:12px;
  }

  .nav a{
    font-size:13px;
  }

  .cta-btn{
    width:100%;
  }

  .header-cta{
    width:100%;
  }
}
</style>