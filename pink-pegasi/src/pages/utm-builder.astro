---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Google Ads & Affiliate UTM Builder | PPC Toolbench"
  description="Build GA4-friendly UTM links for Google Ads, affiliate campaigns, email and social — no sign-up required."
  currentPath="/utm-builder"
>
  <header class="page-header">
    <h1>Google Ads & Affiliate UTM Builder</h1>
    <p class="lead">
      Simple UTM builder for Google Ads, affiliate links and campaign tracking.
      Generate GA4-friendly UTM parameters in seconds.
    </p>
  </header>

  <section class="card">
    <div class="tool-grid">
      <div>
        <h2>Build your UTM URL</h2>

        <div class="field">
          <label for="websiteUrl">Website URL</label>
          <input id="websiteUrl" type="text" placeholder="https://example.com/page" />
          <small class="help">Enter the full page URL, including https://</small>
        </div>

        <div class="field">
          <label for="campaignType">Campaign Type</label>
          <select id="campaignType">
            <option value="google_ads">Google Ads</option>
            <option value="affiliate">Affiliate</option>
            <option value="email">Email</option>
            <option value="social">Social</option>
          </select>
        </div>

        <div class="field">
          <label for="campaignName">Campaign Name</label>
          <input id="campaignName" type="text" placeholder="spring-sale-2026" />
          <small class="help">Use lowercase and hyphens for cleaner GA4 reporting.</small>
        </div>

        <div class="field">
          <label for="source">Source</label>
          <input id="source" type="text" placeholder="google" />
        </div>

        <div class="field">
          <label for="medium">Medium</label>
          <input id="medium" type="text" placeholder="cpc" />
        </div>

        <div class="field">
          <label for="term">Term (optional)</label>
          <input id="term" type="text" placeholder="brand-keyword" />
        </div>

        <div class="field">
          <label for="content">Content (optional)</label>
          <input id="content" type="text" placeholder="ad-variation-a" />
        </div>

        <div class="button-row">
          <button class="btn-primary" id="generateBtn">Generate URL</button>
          <button class="btn-secondary" id="resetBtn" type="button">Reset</button>
        </div>
      </div>

      <div>
        <h2>Generated result</h2>

        <div class="mini-title">Full UTM URL</div>
        <div id="resultUrl" class="output-box">
          Your generated UTM link will appear here.
        </div>

        <div class="button-row" style="margin-top: 12px;">
          <button class="btn-primary" id="copyBtn" type="button">Copy URL</button>
        </div>

        <div class="mini-title" style="margin-top: 18px;">Parameters</div>
        <div id="paramList" class="param-list">
          <div class="param-item">No parameters generated yet.</div>
        </div>

        <div class="mini-title" style="margin-top: 18px;">Naming tips</div>
        <div id="tips" class="tips">
          <div class="tip success">Use lowercase naming for cleaner analytics reporting.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="info-block">
    <h2>Why this tool is useful</h2>
    <ul>
      <li>Prevent inconsistent naming across campaigns and channels.</li>
      <li>Avoid spaces and uppercase issues that make reports messy.</li>
      <li>Create clean URLs for Google Ads, email, affiliates and social campaigns.</li>
      <li>Use GA4-friendly UTM naming conventions from the start.</li>
    </ul>
  </section>

  <section class="info-block">
    <h2>Common questions</h2>

    <details>
      <summary>What are UTMs used for?</summary>
      <p>
        UTM parameters help analytics tools like GA4 understand where your traffic
        came from and which campaigns performed best.
      </p>
    </details>

    <details>
      <summary>What should I use for Google Ads source and medium?</summary>
      <p>
        A common convention is <code>utm_source=google</code> and
        <code>utm_medium=cpc</code>.
      </p>
    </details>

    <details>
      <summary>Should I use lowercase naming?</summary>
      <p>
        Yes. Lowercase naming helps avoid duplicate reporting rows caused by
        inconsistent capitalization.
      </p>
    </details>
  </section>

<section class="info-block">
  <h2>Related Tools</h2>
  <p>
    Need to validate ad copy too? Try our
    <a href="/google-ads-character-counter">Google Ads Character Counter</a>.
  </p>
</section>

  <p class="footer-note">
    No sign-up required. We don’t store your URLs.
  </p>
</MainLayout>

<style>
  .page-header {
    margin-bottom: 24px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    align-items: start;
  }

  .field {
    margin-bottom: 16px;
  }

  label {
    display: block;
    font-weight: 600;
    margin-bottom: 6px;
  }

  input,
  select {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 1rem;
    background: #fff;
  }

  input:focus,
  select:focus {
    outline: 2px solid rgba(109, 40, 217, 0.15);
    border-color: var(--primary);
  }

  .help {
    display: block;
    color: var(--muted);
    font-size: 0.92rem;
    margin-top: 6px;
  }

  .button-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  button {
    border: 0;
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 0.98rem;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--primary-hover);
  }

  .btn-secondary {
    background: #ede9fe;
    color: #4c1d95;
  }

  .output-box {
    background: #f9fafb;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px;
    word-break: break-all;
    min-height: 110px;
  }

  .mini-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: #374151;
    margin-bottom: 8px;
  }

  .param-list {
    display: grid;
    gap: 8px;
    margin-top: 12px;
  }

  .param-item {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 10px 12px;
  }

  .tips {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .tip {
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 0.95rem;
  }

  .tip.success {
    background: var(--success-bg);
    color: var(--success-text);
  }

  .tip.warn {
    background: var(--warn-bg);
    color: var(--warn-text);
  }

  .tip.danger {
    background: var(--danger-bg);
    color: var(--danger-text);
  }

  details {
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 10px;
  }

  summary {
    cursor: pointer;
    font-weight: 600;
  }

  .footer-note {
    margin-top: 24px;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const websiteUrl = document.getElementById("websiteUrl");
  const campaignType = document.getElementById("campaignType");
  const campaignName = document.getElementById("campaignName");
  const source = document.getElementById("source");
  const medium = document.getElementById("medium");
  const term = document.getElementById("term");
  const content = document.getElementById("content");

  const generateBtn = document.getElementById("generateBtn");
  const resetBtn = document.getElementById("resetBtn");
  const copyBtn = document.getElementById("copyBtn");

  const resultUrl = document.getElementById("resultUrl");
  const paramList = document.getElementById("paramList");
  const tips = document.getElementById("tips");

  function applyDefaults() {
    const type = campaignType.value;

    if (type === "google_ads") {
      source.value = "google";
      medium.value = "cpc";
    } else if (type === "affiliate") {
      source.value = "partner";
      medium.value = "affiliate";
    } else if (type === "email") {
      source.value = "newsletter";
      medium.value = "email";
    } else if (type === "social") {
      source.value = "facebook";
      medium.value = "social";
    }
  }

  function normalizeValue(value) {
    return value.trim().replace(/\s+/g, "-");
  }

  function isValidUrl(url) {
    try {
      new URL(url);
      return true;
    } catch {
      return false;
    }
  }

  function renderTips(messages) {
    if (!messages.length) {
      tips.innerHTML = '<div class="tip success">Looks good. Your naming follows clean reporting conventions.</div>';
      return;
    }

    tips.innerHTML = messages.map((msg) => {
      return `<div class="tip ${msg.type}">${msg.text}</div>`;
    }).join("");
  }

  function renderParams(params) {
    const entries = Object.entries(params).filter(([, value]) => value);

    if (!entries.length) {
      paramList.innerHTML = '<div class="param-item">No parameters generated yet.</div>';
      return;
    }

    paramList.innerHTML = entries.map(([key, value]) => {
      return `<div class="param-item"><strong>${key}</strong>: ${value}</div>`;
    }).join("");
  }

  function generateUrl() {
    const rawUrl = websiteUrl.value.trim();
    const rawCampaign = campaignName.value.trim();
    const rawSource = source.value.trim();
    const rawMedium = medium.value.trim();
    const rawTerm = term.value.trim();
    const rawContent = content.value.trim();

    const messages = [];

    if (!rawUrl || !rawCampaign || !rawSource || !rawMedium) {
      resultUrl.textContent = "Please complete Website URL, Campaign Name, Source, and Medium.";
      renderParams({});
      renderTips([
        { type: "danger", text: "Missing required fields. Please fill in all required inputs." }
      ]);
      return;
    }

    if (!isValidUrl(rawUrl)) {
      resultUrl.textContent = "Please enter a valid URL starting with http:// or https://";
      renderParams({});
      renderTips([
        { type: "danger", text: "The website URL is not valid." }
      ]);
      return;
    }

    if (/[A-Z]/.test(rawCampaign) || /[A-Z]/.test(rawSource) || /[A-Z]/.test(rawMedium) || /[A-Z]/.test(rawTerm) || /[A-Z]/.test(rawContent)) {
      messages.push({
        type: "warn",
        text: "Uppercase letters detected. Lowercase is recommended for cleaner analytics."
      });
    }

    if (/\s/.test(rawCampaign) || /\s/.test(rawSource) || /\s/.test(rawMedium) || /\s/.test(rawTerm) || /\s/.test(rawContent)) {
      messages.push({
        type: "warn",
        text: 'Spaces detected. They were replaced with hyphens in the generated values.'
      });
    }

    const params = {
      utm_source: normalizeValue(rawSource),
      utm_medium: normalizeValue(rawMedium),
      utm_campaign: normalizeValue(rawCampaign),
      utm_term: normalizeValue(rawTerm),
      utm_content: normalizeValue(rawContent),
    };

    const url = new URL(rawUrl);

    Object.entries(params).forEach(([key, value]) => {
      if (value) {
        url.searchParams.set(key, value);
      }
    });

    resultUrl.textContent = url.toString();
    renderParams(params);
    renderTips(messages);
  }

  function resetForm() {
    websiteUrl.value = "";
    campaignName.value = "";
    term.value = "";
    content.value = "";
    campaignType.value = "google_ads";
    applyDefaults();

    resultUrl.textContent = "Your generated UTM link will appear here.";
    paramList.innerHTML = '<div class="param-item">No parameters generated yet.</div>';
    tips.innerHTML = '<div class="tip success">Use lowercase naming for cleaner analytics reporting.</div>';
  }

  campaignType.addEventListener("change", applyDefaults);
  generateBtn.addEventListener("click", generateUrl);
  resetBtn.addEventListener("click", resetForm);

  copyBtn.addEventListener("click", async () => {
    const text = resultUrl.textContent.trim();

    if (!text || text === "Your generated UTM link will appear here." || text.startsWith("Please ")) {
      alert("Generate a valid URL first.");
      return;
    }

    try {
      await navigator.clipboard.writeText(text);
      copyBtn.textContent = "Copied!";
      setTimeout(() => {
        copyBtn.textContent = "Copy URL";
      }, 1500);
    } catch {
      alert("Copy failed. Please copy the URL manually.");
    }
  });

  applyDefaults();
</script>