---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Google Ads Keyword Cleaner – Organize & Clean PPC Keyword Lists"
  description="Clean and organize your keyword lists for Google Ads. Free PPC keyword cleaner tool for better campaign structure and management."
  currentPath="/google-ads-keyword-cleaner"
>
  <header class="page-header">
    <h1>Google Ads Keyword Cleaner</h1>
    <p class="lead">
      Clean, normalize, and deduplicate keyword lists for Google Ads campaigns in seconds.
    </p>
  </header>

  <section class="card tool-card">
    <div class="tool-grid">
      <div class="field">
        <label for="rawKeywords">Paste Keywords</label>
        <textarea
          id="rawKeywords"
          rows="14"
          placeholder="Paste one keyword per line&#10;Example:&#10;google ads audit&#10;Google Ads Audit&#10; google ads management &#10;ppc consultant"
        ></textarea>
        <p class="input-meta">Paste one keyword per line.</p>
      </div>

      <div class="field">
        <label>Options</label>

        <div class="option-list">
          <label class="option-item">
            <input type="checkbox" id="trimSpaces" checked />
            <span>Trim extra spaces</span>
          </label>

          <label class="option-item">
            <input type="checkbox" id="removeDuplicates" checked />
            <span>Remove duplicate keywords</span>
          </label>

          <label class="option-item">
            <input type="checkbox" id="toLowercase" />
            <span>Convert to lowercase</span>
          </label>

          <label class="option-item">
            <input type="checkbox" id="removeBlankLines" checked />
            <span>Remove blank lines</span>
          </label>
        </div>

        <div class="button-row">
          <button class="btn-primary" id="cleanBtn" type="button">Clean Keywords</button>
          <button class="btn-secondary" id="resetBtn" type="button">Reset</button>
          <button class="btn-secondary" id="copyBtn" type="button">Copy Output</button>
        </div>

        <div class="stats-box">
          <p><strong>Original lines:</strong> <span id="originalCount">0</span></p>
          <p><strong>Cleaned lines:</strong> <span id="cleanedCount">0</span></p>
          <p><strong>Duplicates removed:</strong> <span id="duplicatesCount">0</span></p>
        </div>
      </div>
    </div>
  </section>

  <section class="card results-card">
    <h2>Cleaned Keyword List</h2>
    <textarea
      id="cleanedKeywords"
      rows="14"
      placeholder="Your cleaned keyword list will appear here."
      readonly
    ></textarea>
  </section>

  <section class="card content-card">
    <h2>What This Tool Does</h2>
    <p>
      This Google Ads Keyword Cleaner helps you clean raw keyword lists before uploading
      them into a PPC campaign. You can remove blank lines, trim spacing, normalize casing,
      and eliminate duplicate keywords.
    </p>

    <h2>Why It Matters</h2>
    <p>
      Messy keyword lists can slow down campaign setup and create avoidable errors. Cleaning
      your keyword list before launch makes campaign structure more consistent and easier to manage.
    </p>

    <h2>How to Use It</h2>
    <ol>
      <li>Paste your raw keyword list into the input box.</li>
      <li>Select the cleanup options you want to apply.</li>
      <li>Click <strong>Clean Keywords</strong>.</li>
      <li>Review the cleaned output and copy it into your workflow.</li>
    </ol>

    <h2>Related Tools</h2>
    <p>
      Build campaign tracking links with our
      <a href="/utm-builder">UTM Builder</a>,
      generate copy using the
      <a href="/google-ads-headline-generator">Google Ads Headline Generator</a>
      and
      <a href="/google-ads-description-generator">Google Ads Description Generator</a>,
      or review final ad layouts with the
      <a href="/google-ads-preview-tool">Google Ads Preview Tool</a>.
    </p>
  </section>

  <script>
    const rawKeywordsEl = document.getElementById("rawKeywords");
    const cleanedKeywordsEl = document.getElementById("cleanedKeywords");

    const trimSpacesEl = document.getElementById("trimSpaces");
    const removeDuplicatesEl = document.getElementById("removeDuplicates");
    const toLowercaseEl = document.getElementById("toLowercase");
    const removeBlankLinesEl = document.getElementById("removeBlankLines");

    const cleanBtn = document.getElementById("cleanBtn");
    const resetBtn = document.getElementById("resetBtn");
    const copyBtn = document.getElementById("copyBtn");

    const originalCountEl = document.getElementById("originalCount");
    const cleanedCountEl = document.getElementById("cleanedCount");
    const duplicatesCountEl = document.getElementById("duplicatesCount");

    function normalizeLine(line) {
      let text = line;

      if (trimSpacesEl.checked) {
        text = text.trim().replace(/\s+/g, " ");
      }

      if (toLowercaseEl.checked) {
        text = text.toLowerCase();
      }

      return text;
    }

    function cleanKeywords() {
      const rawText = rawKeywordsEl.value || "";
      const rawLines = rawText.split("\n");

      originalCountEl.textContent = rawLines.length;

      let processed = rawLines.map(normalizeLine);

      if (removeBlankLinesEl.checked) {
        processed = processed.filter((line) => line !== "");
      }

      let duplicatesRemoved = 0;

      if (removeDuplicatesEl.checked) {
        const seen = new Set();
        processed = processed.filter((line) => {
          if (seen.has(line)) {
            duplicatesRemoved++;
            return false;
          }
          seen.add(line);
          return true;
        });
      }

      cleanedKeywordsEl.value = processed.join("\n");
      cleanedCountEl.textContent = processed.length;
      duplicatesCountEl.textContent = duplicatesRemoved;
    }

    function resetAll() {
      rawKeywordsEl.value = "";
      cleanedKeywordsEl.value = "";
      trimSpacesEl.checked = true;
      removeDuplicatesEl.checked = true;
      toLowercaseEl.checked = false;
      removeBlankLinesEl.checked = true;
      originalCountEl.textContent = "0";
      cleanedCountEl.textContent = "0";
      duplicatesCountEl.textContent = "0";
    }

    async function copyOutput() {
      const text = cleanedKeywordsEl.value;
      if (!text) return;

      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = "Copied!";
        setTimeout(() => {
          copyBtn.textContent = "Copy Output";
        }, 1200);
      } catch (error) {
        copyBtn.textContent = "Copy failed";
        setTimeout(() => {
          copyBtn.textContent = "Copy Output";
        }, 1200);
      }
    }

    cleanBtn.addEventListener("click", cleanKeywords);
    resetBtn.addEventListener("click", resetAll);
    copyBtn.addEventListener("click", copyOutput);
  </script>

  <style>
    .page-header {
      margin-bottom: 24px;
    }

    .tool-card,
    .results-card,
    .content-card {
      margin-top: 24px;
    }

    .tool-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 24px;
      align-items: start;
    }

    .field label:first-child {
      display: block;
      font-weight: 700;
      margin-bottom: 8px;
      font-size: 1.05rem;
    }

    textarea {
      width: 100%;
      padding: 14px 16px;
      border: 1px solid var(--border);
      border-radius: 12px;
      font-size: 1rem;
      font-family: inherit;
      background: #fff;
      resize: vertical;
    }

    textarea:focus {
      outline: 2px solid rgba(109, 40, 217, 0.15);
      border-color: var(--primary);
    }

    .input-meta {
      margin-top: 8px;
      color: #6b7280;
      font-size: 0.92rem;
    }

    .option-list {
      display: grid;
      gap: 12px;
      margin: 8px 0 20px;
    }

    .option-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #374151;
      font-size: 0.98rem;
    }

    .button-row {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    button {
      border: 0;
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 0.98rem;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
    }

    .btn-primary:hover {
      background: var(--primary-hover);
    }

    .btn-secondary {
      background: #ede9fe;
      color: #4c1d95;
    }

    .stats-box {
      padding: 16px;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      background: #fff;
    }

    .stats-box p {
      margin: 0 0 8px;
      color: #374151;
    }

    .stats-box p:last-child {
      margin-bottom: 0;
    }

    .content-card h2 {
      margin-top: 28px;
      margin-bottom: 10px;
    }

    .content-card h2:first-child {
      margin-top: 0;
    }

    .content-card p,
    .content-card li {
      color: #374151;
      font-size: 1.02rem;
      line-height: 1.75;
    }

    @media (max-width: 980px) {
      .tool-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>