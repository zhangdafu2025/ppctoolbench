---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact | PPC Toolbench"
  description="Contact PPC Toolbench for questions, feedback, and partnership inquiries related to our PPC and Google Ads tools."
  currentPath="/contact"
>
  <main class="card contact-card">
    <h1>Contact</h1>

    <p class="lead">
      If you have questions, feedback, or partnership inquiries, feel free to contact us.
    </p>

    <p>
      PPC Toolbench is an independent resource for digital marketers. We build practical,
      free tools for Google Ads workflows, campaign tracking, ad copy validation, and PPC planning.
    </p>

    <div class="contact-box">
      <p class="contact-label">Email</p>
      <p class="contact-email">
        <a href="mailto:ppctoolbench@gmail.com">ppctoolbench@gmail.com</a>
      </p>
    </div>

    <div class="contact-info">
      <h2>What you can contact us about</h2>
      <ul>
        <li>Tool feedback and usability suggestions</li>
        <li>Bug reports or technical issues</li>
        <li>General business or partnership inquiries</li>
        <li>Questions related to PPC Toolbench content and tools</li>
      </ul>
    </div>

    <p class="response-note">
      We typically respond within 24–48 hours.
    </p>
  </main>

  <style>
    .contact-card {
      max-width: 860px;
    }

    .contact-box {
      margin: 28px 0 22px;
      padding: 18px 20px;
      border: 1px solid #ddd6fe;
      background: #f5f3ff;
      border-radius: 14px;
    }

    .contact-label {
      margin: 0 0 6px;
      font-size: 0.92rem;
      font-weight: 700;
      color: #6d28d9;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    .contact-email {
      margin: 0;
      font-size: 1.08rem;
      font-weight: 600;
    }

    .contact-email a {
      color: #111827;
      text-decoration: none;
    }

    .contact-email a:hover {
      color: var(--primary);
      text-decoration: underline;
    }

    .contact-info {
      margin-top: 26px;
    }

    .contact-info h2 {
      margin-bottom: 10px;
    }

    .contact-info ul {
      color: #374151;
      line-height: 1.75;
    }

    .response-note {
      margin-top: 24px;
      color: #6b7280;
      font-size: 0.98rem;
    }
  </style>
</MainLayout>