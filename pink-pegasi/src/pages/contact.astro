---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact | PPC Toolbench"
  description="Contact PPC Toolbench for general questions, feedback, and site-related inquiries."
  currentPath="/contact"
>
  <main class="card">
    <h1>Contact</h1>
    <p class="lead">
      For general questions, feedback, or site-related inquiries, please contact us by email.
    </p>

    <p>
      We welcome feedback about tool usability, bug reports, and general suggestions
      related to PPC Toolbench.
    </p>

    <div class="email-box">
      <strong>Contact email:</strong>
      <span>Email address will be added soon.</span>
    </div>

    <p class="contact-note">
      We aim to review messages as soon as reasonably possible.
    </p>
  </main>
</MainLayout>

<style>
  .email-box {
    margin-top: 20px;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid #ddd6fe;
    background: #f5f3ff;
  }

  .contact-note {
    margin-top: 20px;
    color: #4b5563;
  }
</style>