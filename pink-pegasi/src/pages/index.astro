---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Free PPC Tools for Google Ads Marketers"
  description="Free PPC tools for Google Ads marketers. Build UTM links, check ad copy limits, and generate headline ideas instantly."
  currentPath="/"
>
  <section class="hero">

    <div class="hero-copy">
      <div class="hero-badge">Free PPC Tools</div>
      <h1>Free PPC Tools for Google Ads Marketers</h1>
      <p class="lead">
        Build UTM links, check ad copy limits, and generate headline ideas instantly.
        Practical tools designed for faster campaign setup and cleaner ad workflows.
        Free tools designed for Google Ads marketers and PPC professionals.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/utm-builder">Open UTM Builder</a>
        <a class="btn btn-secondary" href="#tools">Explore Tools</a>
      </div>

      <div class="hero-meta">
        <span>No sign-up required</span>
        <span>Free to use</span>
        <span>Built for Google Ads workflows</span>
      </div>
    </div>

    <div class="hero-panel card">
      <div class="mini-kicker">Popular tools</div>

      <div class="hero-tool-list">
        <a class="hero-tool" href="/utm-builder">
          <strong>UTM Builder</strong>
          <span>Create campaign tracking links for Google Ads and marketing campaigns.</span>
        </a>

        <a class="hero-tool" href="/google-ads-character-counter">
          <strong>Ad Character Counter</strong>
          <span>Check RSA headline and description limits instantly.</span>
        </a>

        <a class="hero-tool" href="/google-ads-headline-generator">
          <strong>Headline Generator</strong>
          <span>Generate headline ideas for responsive search ads.</span>
        </a>
      </div>
    </div>
  </section>
  
  <section class="section" id="tools">
    <div class="section-head">
      <h2>Core Tools</h2>
      <p>
        Focused utilities for campaign tracking, ad validation, and faster PPC execution.
      </p>
    </div>

    <div class="tool-grid">
      <article class="card tool-card">
        <div class="status">Live now</div>
        <h3>Free UTM Builder</h3>
        <p>
          Generate clean campaign tracking URLs for Google Ads, email campaigns,
          social traffic, and marketing analytics.
        </p>
        <ul class="small-list">
          <li>Source and medium defaults</li>
          <li>Campaign naming support</li>
          <li>Copy-ready tracking URLs</li>
        </ul>
        <p><a href="/utm-builder">Open tool →</a></p>
      </article>

      <article class="card tool-card">
        <div class="status">Live now</div>
        <h3>Google Ads Character Counter</h3>
        <p>
          Check Google Ads headline and description length for responsive search ads
          with simple visual feedback.
        </p>
        <ul class="small-list">
          <li>30-character headline checks</li>
          <li>90-character description checks</li>
          <li>Real-time validation</li>
        </ul>
        <p><a href="/google-ads-character-counter">Open tool →</a></p>
      </article>

      <article class="card tool-card">
        <div class="status">Live now</div>
        <h3>Google Ads Headline Generator</h3>
        <p>
          Generate responsive search ad headline ideas from your keyword,
          offer, and brand terms.
        </p>
        <ul class="small-list">
          <li>Fast headline idea generation</li>
          <li>30-character fit guidance</li>
          <li>Useful for PPC brainstorming</li>
        </ul>
        <p><a href="/google-ads-headline-generator">Open tool →</a></p>
      </article>

      <article class="card tool-card">
  <div class="status">Live now</div>
  <h3>Google Ads Preview Tool</h3>
  <p>
    Preview responsive search ads with headlines, descriptions, and display paths
    before launching your campaign.
  </p>
  <ul class="small-list">
    <li>Live ad-style preview</li>
    <li>Headline and description review</li>
    <li>Useful for pre-launch QA</li>
  </ul>
  <p><a href="/google-ads-preview-tool">Open tool →</a></p>
</article>

<article class="card tool-card">
  <div class="status">Live now</div>
  <h3>Google Ads Description Generator</h3>
  <p>
    Generate Google Ads description ideas using your keyword, offer,
    benefit, and call to action.
  </p>
  <ul class="small-list">
    <li>Free RSA description ideas</li>
    <li>90-character guidance</li>
    <li>Useful for PPC copy drafting</li>
  </ul>
  <p><a href="/google-ads-description-generator">Open tool →</a></p>
</article>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Why marketers use PPC Toolbench</h2>
      <p>
        Simple interfaces, practical defaults, and tools built for real paid traffic workflows.
      </p>
    </div>

    <div class="value-grid">
      <div class="card value-card">
        <h3>Built for execution</h3>
        <p>
          No bloated dashboards. Just fast utilities that help you launch campaigns,
          validate copy, and track performance more efficiently.
        </p>
      </div>

      <div class="card value-card">
        <h3>Designed for Google Ads</h3>
        <p>
          Every tool is tailored to practical PPC work, including RSA copy limits,
          headline drafting, and campaign URL building.
        </p>
      </div>

      <div class="card value-card">
        <h3>Free and accessible</h3>
        <p>
          Core tools are available without sign-up, making PPC Toolbench easy to use
          whenever you need quick campaign support.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="card cta-card">
      <div>
        <h2>Start with the most-used tool</h2>
        <p>
          Create campaign links faster with our free UTM Builder for Google Ads and marketing tracking.
        </p>
      </div>

      <div class="cta-actions">
        <a class="btn btn-primary" href="/utm-builder">Open UTM Builder</a>
      </div>
    </div>
  </section>

  <style>
    .hero {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 28px;
      align-items: center;
      padding: 18px 0 10px;
    }

    .hero-badge {
      display: inline-block;
      margin-bottom: 14px;
      padding: 6px 12px;
      border-radius: 999px;
      background: #f3e8ff;
      color: #6d28d9;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .hero-copy h1 {
      font-size: 3.2rem;
      line-height: 1.08;
      margin-bottom: 18px;
      max-width: 720px;
    }

    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 22px;
    }

    .btn {
      display: inline-block;
      padding: 12px 16px;
      border-radius: 10px;
      font-weight: 700;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--primary);
      color: #fff;
    }

    .btn-primary:hover {
      background: var(--primary-hover);
      text-decoration: none;
    }

    .btn-secondary {
      background: #ede9fe;
      color: #4c1d95;
    }

    .btn-secondary:hover {
      text-decoration: none;
    }

    .hero-meta {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
      margin-top: 18px;
      color: #6b7280;
      font-size: 0.96rem;
    }

    .hero-panel {
      padding: 22px;
    }

    .mini-kicker {
      font-size: 0.9rem;
      font-weight: 700;
      color: #6d28d9;
      margin-bottom: 14px;
    }

    .hero-tool-list {
      display: grid;
      gap: 14px;
    }

    .hero-tool {
      display: block;
      padding: 14px 16px;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      background: #fff;
      text-decoration: none;
    }

    .hero-tool strong {
      display: block;
      color: #111827;
      margin-bottom: 4px;
      font-size: 1rem;
    }

    .hero-tool span {
      display: block;
      color: #6b7280;
      font-size: 0.94rem;
      line-height: 1.5;
    }

    .hero-tool:hover {
      border-color: #c4b5fd;
      background: #fcfbff;
      text-decoration: none;
    }

    .section-head {
      margin-bottom: 18px;
    }

    .section-head h2 {
      margin-bottom: 8px;
    }

    .section-head p {
      color: #6b7280;
      margin: 0;
    }

    .tool-grid {
      display: grid;
       grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 18px;
    }

    .tool-card h3,
    .value-card h3 {
      margin-top: 0;
      margin-bottom: 8px;
      font-size: 1.2rem;
    }

    .tool-card p,
    .value-card p {
      color: #4b5563;
      margin-bottom: 14px;
    }

    .status {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 700;
      color: #4c1d95;
      background: #f3e8ff;
      padding: 6px 10px;
      border-radius: 999px;
      margin-bottom: 12px;
    }

    .small-list {
      padding-left: 18px;
      color: #374151;
    }

    .value-grid {
      display: grid;
       grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 18px;
    }

    .cta-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
      padding: 26px;
    }

    .cta-card h2 {
      margin-bottom: 8px;
    }

    .cta-card p {
      margin: 0;
      color: #6b7280;
    }

    .cta-actions {
      flex-shrink: 0;
    }

    @media (max-width: 980px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .hero-copy h1 {
        font-size: 2.5rem;
      }

      .tool-grid,
      .value-grid {
        grid-template-columns: 1fr;
      }

      .cta-card {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</MainLayout>